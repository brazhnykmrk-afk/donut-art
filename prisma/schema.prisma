// Donut Art — Prisma schema
// Images are NEVER stored in the database: Artwork.imageKey / Profile.avatarKey
// reference objects in S3-compatible storage (Cloudflare R2).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile         Profile?
  artworks        Artwork[]
  reviewsWritten  Review[]  @relation("ReviewAuthor")
  reviewsReceived Review[]  @relation("ReviewCreator")

  @@map("users")
}

model Profile {
  id                String  @id @default(cuid())
  userId            String  @unique
  minecraftNickname String  @unique
  discordUsername   String?
  avatarKey         String?
  bio               String? @db.VarChar(500)

  // ── Reserved for future Minecraft account verification (Version 2) ──
  minecraftUuid String?   @unique
  verifiedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([minecraftNickname])
  @@map("profiles")
}

model Artwork {
  id          String  @id @default(cuid())
  title       String  @db.VarChar(100)
  description String  @db.VarChar(2000)
  // Asking price as free text ("500k", "2 diamond blocks") — Donut Art is
  // not a marketplace, so this is informational only.
  price       String? @db.VarChar(50)
  imageKey    String
  published   Boolean @default(true)
  authorId    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([published, createdAt])
  @@map("artworks")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String   @db.VarChar(1000)
  authorId  String
  creatorId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author  User @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  creator User @relation("ReviewCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  // One review per creator per user
  @@unique([authorId, creatorId])
  @@index([creatorId])
  @@map("reviews")
}
