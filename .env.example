# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (local Postgres, Neon, Supabase, Railway, …)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/donut_art"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Set to the public URL of the deployed site (not needed on Vercel)
# AUTH_URL="https://donutart.example.com"

# ─── Image storage ───────────────────────────────────────────────────────────
# "local" — store images in public/uploads on this machine (development)
# "r2"    — Cloudflare R2 / any S3-compatible bucket (production)
STORAGE_DRIVER="local"

# ─── Cloudflare R2 (S3-compatible object storage, STORAGE_DRIVER="r2") ───────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="donut-art"
# Public base URL of the bucket (R2 public bucket URL or a custom domain)
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"
